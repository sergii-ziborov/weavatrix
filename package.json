{
  "name": "weavatrix",
  "version": "0.2.11",
  "type": "module",
  "description": "Local repository intelligence MCP for AI coding agents: reusable architecture graph for fast application understanding, Health, dead code, clones, history, blast radius and architecture safeguards.",
  "author": "Sergii Ziborov <sergii.ziborov@gmail.com>",
  "license": "MIT",
  "homepage": "https://weavatrix.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergii-ziborov/weavatrix.git"
  },
  "bugs": {
    "url": "https://github.com/sergii-ziborov/weavatrix/issues"
  },
  "mcpName": "io.github.sergii-ziborov/weavatrix",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "weavatrix-mcp": "bin/weavatrix-mcp.mjs"
  },
  "files": [
    "bin",
    "src",
    "skill",
    "scripts/run-agent-task-benchmark.mjs",
    "docs/agent-task-benchmark.md",
    "docs/releases/v0.2.11.md",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "benchmark": "node scripts/run-benchmark.mjs",
    "benchmark:quick": "node scripts/run-benchmark.mjs --quick",
    "benchmark:real": "node scripts/run-real-benchmark.mjs",
    "benchmark:real:release": "node scripts/run-real-benchmark.mjs --require-all",
    "benchmark:agent": "node scripts/run-agent-task-benchmark.mjs",
    "benchmark:agent:release": "node scripts/run-agent-task-benchmark.mjs --require-independent",
    "build:mcpb": "node scripts/build-mcpb.mjs",
    "verify:release": "node scripts/verify-release.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "code-graph",
    "impact-analysis",
    "blast-radius",
    "static-analysis",
    "dead-code",
    "dependency-graph",
    "tree-sitter",
    "claude",
    "ai-agents"
  ],
  "dependencies": {
    "tree-sitter-wasms": "0.1.13",
    "typescript": "5.9.3",
    "typescript-language-server": "4.4.1",
    "web-tree-sitter": "0.25.10"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "2.1.2"
  },
  "overrides": {
    "tmp": "0.2.7"
  }
}
